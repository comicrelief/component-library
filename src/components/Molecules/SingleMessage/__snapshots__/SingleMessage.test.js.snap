exports[`renders Single Message with full width correctly 1`] = `
.c6 {
  font-family: 'Anton',Impact,sans-serif;
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: 0;
  font-size: 2rem;
  line-height: 2rem;
}

.c6 {
  font-size: 3rem;
  line-height: normal;
  color: #FFFFFF;
}

.c6 span {
  font-size: inherit;
  line-height: inherit;
}

.c7 {
  font-family: 'Montserrat',Helvetica,Arial,sans-serif;
  font-weight: 400;
  text-transform: inherit;
  letter-spacing: 0;
  font-size: 1rem;
  line-height: 1.25rem;
}

.c7 {
  font-size: 1rem;
  line-height: normal;
  color: #FFFFFF;
}

.c7 span {
  font-size: inherit;
  line-height: inherit;
}

.c3 {
  display: block;
  width: 100%;
  height: 100%;
  position: relative;
}

.c4 {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

.c8 {
  display: inline-flex;
  position: relative;
  text-decoration: none;
  transition: all 0.2s;
  height: 2.5rem;
  width: 100%;
  justify-content: center;
  align-items: center;
  border: none;
  cursor: pointer;
  padding: 0.6rem 1rem;
  border-radius: 0.5rem;
  background-color: #FFFFFF;
  color: #000000;
  font-family: 'Montserrat',Helvetica,Arial,sans-serif;
  font-weight: 700;
  text-transform: inherit;
  letter-spacing: 0;
  font-size: 1rem;
  line-height: 1.25rem;
}

.c8:hover,
.c8:focus,
.c8:focus-within,
.c8:focus-visible {
  background-color: #E1E2E3;
  outline-offset: 3px;
}

.c8:disabled {
  cursor: not-allowed;
  opacity: 0.5;
}

.c0 {
  display: flex;
  position: relative;
  flex-direction: column;
  overflow: hidden;
  background: #6F3AAB;
  padding-top: 0rem;
  padding-bottom: 0rem;
}

.c0 iframe {
  height: 100%;
  width: 100%;
  position: absolute;
  top: 0;
  left: 0;
  right: auto;
  z-index: 0;
}

.c5 {
  width: 100%;
  z-index: 1;
  padding: 0 2rem;
}

.c1 {
  width: 100%;
  height: 200px;
  position: relative;
}

.c2 {
  width: 100%;
  height: 100%;
  z-index: 1;
}

@media (min-width: 740px) {
  .c6 {
    font-size: 2.5rem;
    line-height: 2.5rem;
  }
}

@media (min-width: 1024px) {
  .c6 {
    font-size: 3rem;
    line-height: 3rem;
  }
}

@media (min-width: 740px) {
  .c7 {
    font-size: 1rem;
    line-height: 1.25rem;
  }
}

@media (min-width: 1024px) {
  .c7 {
    font-size: 1.125rem;
    line-height: 1.375rem;
  }
}

@media (min-width: 740px) {
  .c8 {
    font-size: 1rem;
    line-height: 1.25rem;
  }
}

@media (min-width: 1024px) {
  .c8 {
    font-size: 1.125rem;
    line-height: 1.375rem;
  }
}

@media (min-width: 740px) {
  .c8 {
    width: auto;
  }
}

@media (min-width: 1024px) {
  .c8 {
    width: auto;
  }
}

@media (min-width: 740px) {
  .c0 {
    flex-direction: row;
    padding-top: 0rem;
    padding-bottom: 0rem;
  }
}

@media (min-width: 740px) {
  .c5 {
    min-height: calc(100vh - 5.625rem);
    flex-direction: column;
    justify-content: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 4rem;
  }
}

@media (min-width: 740px) {
  .c5 {
    position: absolute;
    width: 100%;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 50%;
  }
}

@media (min-width: 740px) {
  .c5 {
    width: 50%;
  }
}

@media (min-width: 740px) {
  .c1 {
    height: auto;
    width: 100%;
    min-height: 500px;
  }
}

@media (min-width: 740px) {
  .c1 {
    padding-bottom: 0;
  }
}

@media (min-width: 740px) {
  .c2 img {
    position: absolute;
  }
}

