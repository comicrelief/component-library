        </div>
        <div
          aria-atomic="true"
          aria-live="polite"
          className="c15"
          id="lightboxDescription"
        />
        <button
          className="c9 c16 close-button"
          onClick={[Function]}
          type="button"
        >
          <span
            className="c11"
          >
