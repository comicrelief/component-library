              />
              <span
                className="css-1v7m6ew"
              />
            </span>
          </div>
          <button
            className="c9 c10"
            onClick={[Function]}
            type="button"
          >
            <span
              className="c11"
            >
              Previous
            </span>
            <svg
              className="c12"
              direction="left"
              height={16}
